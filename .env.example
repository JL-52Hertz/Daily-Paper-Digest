# LLM_PROVIDER supports:
# deepseek, openai, anthropic, dashscope, volcengine, qianfan, openai_compatible, ollama, llama_cpp.
# China provider aliases:
# dashscope = aliyun/alibaba/qwen/bailian, volcengine = ark/doubao/bytedance, qianfan = baidu/wenxin/ernie.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
# Leave blank to use the built-in default for the selected provider.
LLM_BASE_URL=
WECOM_WEBHOOK_URL=
WECOM_MESSAGE_TYPE=text
WECOM_TEXT_CHUNK_CHARS=1800
# zh = Chinese WeCom digest, en = English WeCom digest.
PAPER_DIGEST_SUMMARY_LANGUAGE=zh
S2_API_KEY=
PAPER_DIGEST_TOPICS=vlm
PAPER_DIGEST_TOPIC_CONFIG=config/topics.json
PAPER_DIGEST_SEND_TIMES=08:00
# Optional: route configured send times to configured topics.
# Times must exist in PAPER_DIGEST_SEND_TIMES; topics must exist in PAPER_DIGEST_TOPICS.
# Example: PAPER_DIGEST_TIME_TOPICS=08:00=vlm,detection;21:00=efficient_training
PAPER_DIGEST_TIME_TOPICS=
TZ=Asia/Shanghai
